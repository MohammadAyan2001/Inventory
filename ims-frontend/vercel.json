{
  "buildCommand": "npm run build:prod",
  "outputDirectory": "dist/ims-frontend/browser",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://inventory-kx0o.onrender.com/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
